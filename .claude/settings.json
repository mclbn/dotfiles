{
  "env": {
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(diff *)",
      "Bash(tree *)",
      "Bash(which *)",
      "Bash(file *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(./secrets/**)",
      "Read(**/*credentials*)",
      "Read(**/*secret*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.keystore)",
      "Read(**/*.jks)",
      "Read(**/*.kdbx)",
      "Read(**/*.kdb)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.azure/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.docker/config.json)",
      "Read(~/.kube/config)",
      "Read(~/.terraform.d/**)",
      "Read(~/.vault-token)",
      "Read(~/.claude/.credentials.json)",
      "Read(~/.netrc)",
      "Read(~/.npmrc)",
      "Read(~/.pypirc)",
      "Read(~/.git-credentials)",
      "Read(~/.gitconfig)",
      "Read(~/.local/share/keyrings/**)",
      "Read(~/.zshrc)",
      "Read(~/.zshrc.local)",
      "Read(~/.zshenv)",
      "Read(~/.zshenv.local)",
      "Read(~/.bashrc)",
      "Read(~/.bash_profile)",
      "Read(~/.profile)",
      "Read(~/.zsh_history)",
      "Read(~/.bash_history)",
      "Read(~/.history)",
      "Read(~/log/**)",
      "Read(~/missions/**)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(nc *)",
      "Bash(ncat *)",
      "Bash(nmap *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(rsync *)",
      "Bash(ftp *)",
      "Bash(sftp *)",
      "Bash(telnet *)",
      "Bash(socat *)",
      "Bash(printenv *)",
      "Bash(printenv)",
      "Bash(env *)",
      "Bash(env)",
      "Bash(set *)",
      "Bash(set)",
      "Bash(export -p)",
      "Bash(declare -p)",
      "Bash(declare -p *)",
      "Bash(compgen *)",
      "Bash(compgen)",
      "Bash(history *)",
      "Bash(history)",
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(pkexec *)",
      "Bash(secret-tool *)",
      "Bash(keyctl *)",
      "Bash(dbus-send *)",
      "Bash(pass *)",
      "Bash(pass)",
      "Bash(gpg *)",
      "Bash(op *)",
      "Bash(bw *)",
      "Bash(keepassxc-cli *)",
      "Bash(keepassxc-cli)",
      "Bash(xclip *)",
      "Bash(xclip)",
      "Bash(xsel *)",
      "Bash(xsel)",
      "Bash(wl-paste *)",
      "Bash(wl-paste)",
      "Bash(wl-copy *)",
      "Bash(wl-copy)",
      "Bash(pbpaste *)",
      "Bash(pbpaste)",
      "Bash(xdg-open *)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git remote *)",
      "Bash(docker *)",
      "Bash(npm publish *)",
      "Bash(gh *)",
      "Bash(base64 *)",
      "Bash(base64)",
      "Bash(xxd *)",
      "Bash(xxd)",
      "Bash(od *)",
      "Bash(od)",
      "Bash(hexdump *)",
      "Bash(hexdump)",
      "Bash(strings *)",
      "Bash(strings)",
      "Edit(./Makefile)",
      "Edit(./.git/**)",
      "Write(./.git/**)",
      "Edit(./.github/**)",
      "Write(./.github/**)",
      "Edit(./.gitlab-ci.yml)",
      "Write(./.gitlab-ci.yml)",
      "Edit(./Dockerfile*)",
      "Edit(./docker-compose*)",
      "WebFetch(*)"
    ],
    "disableBypassPermissionsMode": "disable"
  },
  "model": "opus[1m]",
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowUnixSockets": [],
      "allowLocalBinding": false
    },
    "filesystem": {
      "allowWrite": [
        "/tmp"
      ],
      "denyWrite": [
        "/etc",
        "/usr",
        "/bin",
        "/sbin",
        "~/.ssh",
        "~/.aws",
        "~/.gnupg",
        "~/.bashrc",
        "~/.bash_profile",
        "~/.profile",
        "~/.zshrc",
        "~/.zshrc.local",
        "~/.zshenv",
        "~/.zshenv.local",
        "~/log"
      ],
      "denyRead": [
        "~/.ssh",
        "~/.aws",
        "~/.azure",
        "~/.gnupg",
        "~/.config/gcloud",
        "~/.config/gh",
        "~/.docker",
        "~/.kube",
        "~/.terraform.d",
        "~/.netrc",
        "~/.npmrc",
        "~/.pypirc",
        "~/.password-store",
        "~/.git-credentials",
        "~/.vault-token",
        "~/.local/share/keyrings",
        "~/.claude/.credentials.json",
        "~/.zshenv.local",
        "~/.zshrc.local",
        "~/.zsh_history",
        "~/.bash_history",
        "~/.history",
        "~/log",
        "/proc/self/environ"
      ],
      "allowRead": [
        "."
      ]
    },
    "excludedCommands": [
      "docker *"
    ]
  }
}
